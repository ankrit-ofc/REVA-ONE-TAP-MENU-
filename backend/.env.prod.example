# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION environment for the backend + database containers.
# On the server:  cp backend/.env.prod.example backend/.env   then fill in values.
# The copied backend/.env is gitignored and never leaves the server.
# Replace every REPLACE_... value and every "order.yourdomain.com" with your domain.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application secrets (REQUIRED) ───────────────────────────────────────────
# Generate each with:  openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_64_HEX_CHARS
QR_SECRET=REPLACE_WITH_DIFFERENT_64_HEX_CHARS

# Production hardening: disables /docs & /redoc and tightens behaviour.
ENVIRONMENT=production

# ── Auth / token lifetimes (optional; defaults are sensible) ─────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=5
REFRESH_TOKEN_EXPIRE_HOURS=12
REFRESH_TOKEN_DISPLAY_EXPIRE_HOURS=168
REMEMBER_ME_REFRESH_TOKEN_EXPIRE_HOURS=720
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# ── Database ─────────────────────────────────────────────────────────────────
# The app connects as the restricted role tenant_app_user (NOT the superuser).
# The password here MUST equal APP_DB_PASSWORD below.
DATABASE_URL=postgresql+psycopg://tenant_app_user:REPLACE_WITH_APP_DB_PASSWORD@db:5432/appdb

# Postgres container first-run init (superuser + database name).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_SUPERUSER_PASSWORD
POSTGRES_DB=appdb

# Password for the restricted tenant_app_user role (must match DATABASE_URL).
APP_DB_PASSWORD=REPLACE_WITH_APP_DB_PASSWORD

# ── URLs (single-domain deployment: all three are your one domain) ───────────
BACKEND_BASE_URL=https://order.yourdomain.com
FRONTEND_BASE_URL=https://order.yourdomain.com

# ── CORS ─────────────────────────────────────────────────────────────────────
# Same-origin in production, so just your domain. Never use * here.
ALLOWED_ORIGINS=https://order.yourdomain.com

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_SCAN=20/minute
RATE_LIMIT_ORDERS=30/minute
RATE_LIMIT_PASSWORD_RESET=3/minute

# ── Email / SMTP (password-reset emails) ─────────────────────────────────────
# Leave SMTP_HOST empty to have reset links written to the backend log instead of
# emailed (fine for a demo). Fill these in to send real mail.
# NOTE: rotate any Gmail app password that was previously committed to the repo.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@order.yourdomain.com
SMTP_USE_TLS=true

# ── Payment gateways (Nepal) — SANDBOX/DEMO ──────────────────────────────────
# For a sandbox demo you can leave these commented out: the app falls back to the
# built-in eSewa test credentials (product code EPAYTEST). Khalti/Fonepay stay
# inactive until you add real keys. Fill these in only when going LIVE (requires
# merchant onboarding) and register the webhook URLs below in each dashboard.
#   eSewa redirect:  https://order.yourdomain.com/webhooks/esewa
#   Khalti redirect: https://order.yourdomain.com/webhooks/khalti
#   Fonepay POST:    https://order.yourdomain.com/webhooks/fonepay
# ESEWA_SECRET_KEY=REPLACE_WITH_ESEWA_SECRET_KEY
# ESEWA_PRODUCT_CODE=REPLACE_WITH_MERCHANT_CODE
# KHALTI_SECRET_KEY=REPLACE_WITH_KHALTI_SECRET_KEY
KHALTI_WEBSITE_URL=https://order.yourdomain.com
# FONEPAY_MERCHANT_CODE=REPLACE_WITH_FONEPAY_MERCHANT_CODE
# FONEPAY_SECRET_KEY=REPLACE_WITH_FONEPAY_SECRET_KEY

# ── AR / 3D model providers ──────────────────────────────────────────────────
# Provider adapters are selected by name. Leave both as "dummy" (the default) to
# run with no external calls (hardcoded spike model + canned nutrition). To use the
# real pipeline, set the providers below and fill in the keys. Keys stay server-side.
# The model ids are config so you can downgrade to a cheaper model with the SAME key.
AR_THREED_PROVIDER=dummy      # dummy | fal
AR_MARKING_PROVIDER=dummy     # dummy | claude
AR_USDZ_CONVERTER=dummy       # dummy | sidecar (headless-Blender model-converter container)
# FAL_KEY=REPLACE_WITH_FAL_KEY
# ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_API_KEY
# Default 3D model when the admin doesn't pick one in the generate dropdown.
# hunyuan3d-v3 ($0.375) | hunyuan3d-v2-multiview (~$0.05) | trellis-multi (~$0.02)
# AR_DEFAULT_THREED_MODEL=hunyuan3d-v2-multiview
# AR_MARKING_MODEL=claude-sonnet-4-6
# Generated GLBs are downloaded into /media and compressed (meshopt + WebP).
# AR_COMPRESS_MODELS=true
# AR_MODEL_TEXTURE_SIZE=2048
# MODEL_CONVERTER_URL=http://model-converter:9000
