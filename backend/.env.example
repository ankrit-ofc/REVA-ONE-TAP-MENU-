# ── Application ──────────────────────────────────────────────────────────────
# Required. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_SECRET_KEY

# QR signing secret (independent of SECRET_KEY).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
QR_SECRET=REPLACE_WITH_QR_SECRET

# "development" | "staging" | "production"
ENVIRONMENT=development

# ── Auth / token lifetimes ────────────────────────────────────────────────────
# Optional (defaults shown). Access token is short; the refresh token is a
# sliding window — re-opening within it resets the clock. The counter wall
# display (COUNTER_DISPLAY) gets a long window so it never logs itself out.
ACCESS_TOKEN_EXPIRE_MINUTES=5
REFRESH_TOKEN_EXPIRE_HOURS=12
REFRESH_TOKEN_DISPLAY_EXPIRE_HOURS=168
# "Remember me" extends the refresh window (non-DISPLAY roles) this far.
REMEMBER_ME_REFRESH_TOKEN_EXPIRE_HOURS=720
# Forgot-password reset link validity (minutes).
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# ── Database (app connection) ─────────────────────────────────────────────────
# The app connects as the restricted role tenant_app_user, NOT as the postgres superuser.
# Format: postgresql+psycopg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+psycopg://tenant_app_user:REPLACE_WITH_APP_DB_PASSWORD@db:5432/appdb

# ── Docker Postgres init ──────────────────────────────────────────────────────
# Used only by the postgres container at first-run initialization.
POSTGRES_USER=REPLACE_WITH_POSTGRES_SUPERUSER_USERNAME
POSTGRES_PASSWORD=REPLACE_WITH_POSTGRES_SUPERUSER_PASSWORD
POSTGRES_DB=REPLACE_WITH_DB_NAME

# Password for the restricted tenant_app_user role (must match DATABASE_URL above).
APP_DB_PASSWORD=REPLACE_WITH_APP_DB_PASSWORD

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. Never use * in production.
# Example for production: ALLOWED_ORIGINS=https://order.yourrestaurant.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Tighten these in production. Format: "N/period" (period: second/minute/hour).
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_SCAN=20/minute
RATE_LIMIT_ORDERS=30/minute
RATE_LIMIT_PASSWORD_RESET=3/minute
# Proxy IPs/CIDRs whose X-Forwarded-For is trusted for client-IP resolution.
# Default (172.16.0.0/12) covers the Docker network where Caddy runs.
# TRUSTED_PROXY_IPS=172.16.0.0/12

# ── Email / SMTP (password reset) ─────────────────────────────────────────────
# Leave SMTP_HOST empty in dev: the reset link is written to the backend log
# instead of being emailed. Fill these in to send real mail in production.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@yourrestaurant.com
SMTP_USE_TLS=true

# ── Payment gateways (Nepal) ──────────────────────────────────────────────────
# There are NO gateway defaults in code. A gateway with empty values is simply
# disabled (CASH/CARD/manual still work). When ENVIRONMENT=production the app
# REFUSES TO BOOT if a gateway is partially configured, or if the eSewa
# sandbox credentials below are still in place (app/core/config.py validator).

# eSewa ePay v2 — the values below are eSewa's PUBLIC sandbox credentials for
# dev/testing. Replace with YOUR merchant credentials before production.
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q(
ESEWA_PRODUCT_CODE=EPAYTEST

# Khalti — set your live secret key in production; empty = disabled.
KHALTI_SECRET_KEY=
KHALTI_WEBSITE_URL=https://yourfrontend.com

# Fonepay — set BOTH values or NEITHER; empty = disabled.
FONEPAY_MERCHANT_CODE=
FONEPAY_SECRET_KEY=

# ── URLs ──────────────────────────────────────────────────────────────────────
BACKEND_BASE_URL=https://api.yourrestaurant.com
FRONTEND_BASE_URL=https://order.yourrestaurant.com

# ── AR / 3D model providers ───────────────────────────────────────────────────
# Adapters are selected by name. Default "dummy" makes no external calls (hardcoded
# spike model + canned nutrition). To use the real pipeline set both providers and
# add the keys below. Keys stay server-side. Model ids are config, so you can
# downgrade to a cheaper model with the SAME key (no code change).
AR_THREED_PROVIDER=dummy      # dummy | fal
AR_MARKING_PROVIDER=dummy     # dummy | claude
AR_USDZ_CONVERTER=dummy       # dummy | sidecar (headless-Blender model-converter container)
# FAL_KEY=REPLACE_WITH_FAL_KEY
# ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_API_KEY
# Default 3D model when the admin doesn't pick one in the generate dropdown.
# hunyuan3d-v3 ($0.375) | hunyuan3d-v2-multiview (~$0.05) | trellis-multi (~$0.02)
# AR_DEFAULT_THREED_MODEL=hunyuan3d-v2-multiview
# AR_MARKING_MODEL=claude-sonnet-4-6
# Generated GLBs are downloaded into /media and compressed (meshopt + WebP).
# AR_COMPRESS_MODELS=true
# AR_MODEL_TEXTURE_SIZE=2048
# MODEL_CONVERTER_URL=http://model-converter:9000
