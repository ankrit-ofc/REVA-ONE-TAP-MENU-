# Root-level env used by docker-compose.prod.yml for Caddy (HTTPS).
# On the server:  cp .env.prod.example .env   and fill in real values.
# This file is safe to commit; the copied .env is gitignored.

# Your domain (the exact host you pointed at the VPS IP). No https://, no slash.
DOMAIN=order.yourdomain.com

# Email Let's Encrypt uses for cert expiry notices.
ACME_EMAIL=you@example.com
